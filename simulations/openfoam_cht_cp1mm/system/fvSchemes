//   Top-level fvSchemes -- minimal, required by checkMesh / foamToVTK.
//   Per-region schemes (Phase D) will live in system/{fluid,cold_plate,tim,die}/fvSchemes.
// ============================================================================

FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSchemes;
}

ddtSchemes      { default none; }
gradSchemes     { default Gauss linear; }
divSchemes      { default none; }
laplacianSchemes { default none; }
interpolationSchemes { default linear; }
snGradSchemes   { default corrected; }

