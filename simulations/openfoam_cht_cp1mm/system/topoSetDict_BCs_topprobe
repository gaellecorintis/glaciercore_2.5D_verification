/*--------------------------------*- C++ -*----------------------------------*\
  Diagnostic ONLY (read-only): how many TOP-surface faces (z~0.0015, normal +z)
  exist at the glaciercore inlet/outlet x-y locations? Tries exact glaciercore
  boxes AND widened boxes so we can size the real strips.
\*---------------------------------------------------------------------------*/
FoamFile { version 2.0; format ascii; class dictionary; object topoSetDict; }

actions
(
    // ---- 0. the whole TOP ceiling of the fluid (upward-facing faces) -------
    { name top; type faceSet; action new;  source patchToFace;
      sourceInfo { name fluid_to_cold_plate; } }
    { name top; type faceSet; action subset; source normalToFace;
      sourceInfo { normal (0 0 1); cos 0.8; } }   // keep upward faces (ceiling)

    // ---- INLET 1 : exact glaciercore  x[0.0264,0.0265] y[0,0.0187] ---------
    { name in1_exact; type faceSet; action new; source faceToFace;
      sourceInfo { set top; } }
    { name in1_exact; type faceSet; action subset; source boxToFace;
      sourceInfo { box (0.0264 -1e-4 0.0010) (0.0265 0.0187 0.0016); } }

    // ---- INLET 1 : widened in x (0.0262..0.0267) --------------------------
    { name in1_wide; type faceSet; action new; source faceToFace;
      sourceInfo { set top; } }
    { name in1_wide; type faceSet; action subset; source boxToFace;
      sourceInfo { box (0.0262 -1e-4 0.0010) (0.0268 0.0187 0.0016); } }

    // ---- INLET 2 : exact glaciercore  x[0.0139,0.0262] y[0.0188,0.0189] ----
    { name in2_exact; type faceSet; action new; source faceToFace;
      sourceInfo { set top; } }
    { name in2_exact; type faceSet; action subset; source boxToFace;
      sourceInfo { box (0.0139 0.0188 0.0010) (0.0262 0.0189 0.0016); } }

    // ---- INLET 2 : widened in y (0.0185..0.0192) --------------------------
    { name in2_wide; type faceSet; action new; source faceToFace;
      sourceInfo { set top; } }
    { name in2_wide; type faceSet; action subset; source boxToFace;
      sourceInfo { box (0.0139 0.0185 0.0010) (0.0262 0.0192 0.0016); } }

    // ---- OUTLET : exact glaciercore  x[0,0.0001] y[0,0.0358] --------------
    { name out_exact; type faceSet; action new; source faceToFace;
      sourceInfo { set top; } }
    { name out_exact; type faceSet; action subset; source boxToFace;
      sourceInfo { box (-1e-4 -1e-4 0.0010) (0.0001 0.0358 0.0016); } }

    // ---- OUTLET : widened in x (0..0.0006) --------------------------------
    { name out_wide; type faceSet; action new; source faceToFace;
      sourceInfo { set top; } }
    { name out_wide; type faceSet; action subset; source boxToFace;
      sourceInfo { box (-1e-4 -1e-4 0.0010) (0.0006 0.0358 0.0016); } }
);
