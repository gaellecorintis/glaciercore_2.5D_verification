//  topoSetDict_BCs  --  carve inlet_1, inlet_2, outlet as 2D STRIPS lying on
//                       the TOP surface of the fluid channel (z ~ 0.0015,
//                       upward-facing ceiling = the fluid_to_cold_plate face),
//                       matching the Glaciercore "*_surfaces" definition where
//                       each opening is a flat x-y rectangle of area dx*dy.
//
//  WHY the top surface (vs vertical edge walls): Glaciercore is a 2D model and
//  defines its inlet/outlet as flat x-y surfaces; the inlet velocity follows
//  from |U| = Q / (dx*dy). To reproduce the SAME inlet velocity we must give
//  the patch the SAME x-y area -> a thin strip on the ceiling, not the full
//  channel-height vertical wall (which had ~9x the area -> ~9x too slow).
//
//  Glaciercore reference (settings_sim.json):
//      inlet_surfaces:
//        { x0 0.0264, y0 0.0,    dx 0.0001, dy 0.0187 }   -> INLET 1
//        { x0 0.0139, y0 0.0188, dx 0.0123, dy 0.0001 }   -> INLET 2
//      outlet_surfaces:
//        { x0 0.0,    y0 0.0,    dx 0.0001, dy 0.0358 }   -> OUTLET
//
//  Mesh frame (metres):  X[0,0.0267]  Y[0,0.0430]  Z[0,0.0015]
//
//  Run:  topoSet     -region fluid -dict system/topoSetDict_BCs
//        createPatch -region fluid -overwrite -dict system/createPatchDict
//
//  Idempotent: `top` also re-absorbs any inlet_1/inlet_2/outlet faces created
//  by a prior run (then re-filters by +z normal), so re-running is safe.
// ============================================================================

FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      topoSetDict;
}

actions
(
    // ---- 0. the fluid channel CEILING (top face, upward normal +z) ---------
    {   name top; type faceSet; action new;  source patchToFace;
        sourceInfo { name fluid_to_cold_plate; } }
    {   name top; type faceSet; action add;  source patchToFace;
        sourceInfo { name inlet_1; } }   // re-absorb prior-run strips (if any)
    {   name top; type faceSet; action add;  source patchToFace;
        sourceInfo { name inlet_2; } }
    {   name top; type faceSet; action add;  source patchToFace;
        sourceInfo { name outlet; } }
    {   name top; type faceSet; action subset; source normalToFace;
        sourceInfo { normal (0 0 1); cos 0.8; } }   // keep only the ceiling

    // ---- 1. INLET 1 : x in [0.0264,0.0265], y in [0,0.0187] ----------------
    {   name in1Faces; type faceSet; action new; source faceToFace;
        sourceInfo { set top; } }
    {   name in1Faces; type faceSet; action subset; source boxToFace;
        sourceInfo { box (0.0264 -1e-4 0.0010) (0.0265 0.0187 0.0016); } }

    // ---- 2. INLET 2 : y in [0.0188,0.0189], x in [0.0139,0.0262] -----------
    {   name in2Faces; type faceSet; action new; source faceToFace;
        sourceInfo { set top; } }
    {   name in2Faces; type faceSet; action subset; source boxToFace;
        sourceInfo { box (0.0139 0.0188 0.0010) (0.0262 0.0189 0.0016); } }

    // ---- 3. OUTLET : x in [0,0.0001], y in [0,0.0358] ----------------------
    {   name outFaces; type faceSet; action new; source faceToFace;
        sourceInfo { set top; } }
    {   name outFaces; type faceSet; action subset; source boxToFace;
        sourceInfo { box (-1e-4 -1e-4 0.0010) (0.0001 0.0358 0.0016); } }
);

